    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json)\nreturn [{ json: { _key: 'por_dia', data: rows } }]"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1040, 520],
      "id": "dia-w2-0000-0000-0000-000000000002",
      "name": "Wrap Por Dia"
    },

    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  COALESCE(NULLIF(TRIM(c.bairro), ''), 'Não informado') AS bairro,\n  COUNT(*) AS total\nFROM chamados c\nWHERE c.data BETWEEN '{{ $json.inicio }}' AND '{{ $json.fim }}'\n  AND c.id_tipo IN ({{ $json.inClause }})\nGROUP BY c.bairro\nORDER BY total DESC\nLIMIT 20",
        "options": {}
      },
