    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  c.data AS dia,\n  COUNT(*) AS total,\n  SUM(c.encerrado = 's') AS encerrados\nFROM chamados c\nWHERE c.data BETWEEN '{{ $json.inicio }}' AND '{{ $json.fim }}'\n  AND c.id_tipo IN ({{ $json.inClause }})\nGROUP BY c.data\nORDER BY c.data ASC",
        "options": {}
