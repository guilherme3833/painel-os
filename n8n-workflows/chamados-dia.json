    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  COUNT(*) AS total,\n  SUM(c.encerrado = 's') AS encerrados,\n  SUM(c.encerrado = 'n') AS abertos\nFROM chamados c\nWHERE c.data BETWEEN '{{ $json.inicio }}' AND '{{ $json.fim }}'\n  AND c.id_tipo IN ({{ $json.inClause }})",
        "options": {}
      },
