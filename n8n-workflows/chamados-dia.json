    {
      "parameters": {
        "jsCode": "const items = $input.all().map(i => i.json)\n\nfunction get(key) {\n  return items.find(i => i._key === key)?.data || []\n}\n\nconst totaisRow = get('totais')[0] || { total: 0, encerrados: 0, abertos: 0 }\n\nconst resultado = {\n  totais: {\n    total: Number(totaisRow.total),\n    encerrados: Number(totaisRow.encerrados),\n    abertos: Number(totaisRow.abertos)\n  },\n  por_dia: get('por_dia').map(d => ({ dia: d.dia, total: Number(d.total), encerrados: Number(d.encerrados) })),\n  por_bairro: get('por_bairro').map(d => ({ bairro: d.bairro, total: Number(d.total) }))\n}\n\nreturn [{ json: { body: JSON.stringify(resultado) } }]"
      },
